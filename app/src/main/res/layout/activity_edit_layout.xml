<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E12">

    <FrameLayout
        android:id="@+id/canvasRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgWallpaperEdit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:color/black"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvOperatorEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="9dp"
            android:elevation="10dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:fontFamily="@font/samsung_one_400"
            android:marqueeRepeatLimit="marquee_forever"
            android:maxWidth="150dp"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="TELKOMSEL · Emergency call only"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/statusBarEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="9dp"
            android:paddingEnd="27dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="15dp"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_wifi"
                android:contentDescription="@null"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:src="@drawable/ic_4g"
                    android:contentDescription="@null"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_signal_plain"
                    android:contentDescription="@null"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="2dp"
                    android:src="@drawable/ic_4g"
                    android:contentDescription="@null"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_signal_plain"
                    android:contentDescription="@null"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_battery_dynamic"
                android:fontFamily="@font/samsung_one_400"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:paddingStart="1dp"
                android:text="90"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvClockEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="290dp"
            android:fontFamily="@font/samsung_one_700"
            android:letterSpacing="0"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="10"
            android:text="06:13"
            android:textColor="#FFFFFF"
            android:textSize="84sp" />

        <TextView
            android:id="@+id/tvDateEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="395dp"
            android:fontFamily="@font/samsung_one_700"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="5"
            android:text="Sat, Jan 24"
            android:textColor="#FFFFFF"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/tvMarqueeEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="100dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="Running Text"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <View
            android:id="@+id/vGuideVertical"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="#66A78BFA"
            android:visibility="gone" />

        <View
            android:id="@+id/vGuideHorizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="#66A78BFA"
            android:visibility="gone" />

        <View
            android:id="@+id/viewActiveIndicator"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_editor_active_outline"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#1E1E26"
        app:cardCornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExitEditor"
            android:layout_width="70dp"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:text="Exit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="#00141414"
            app:cornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutCardLiftButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCardUp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="▲"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#4E312BE2"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCardDown"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="▼"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#4E312BE2"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutControlContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00141414"
            android:elevation="16dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeft"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="◀"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    app:backgroundTint="#2C2C2E"
                    app:cornerRadius="14dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUp"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="▲"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        app:backgroundTint="#2C2C2E"
                        app:cornerRadius="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDown"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="▼"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        app:backgroundTint="#2C2C2E"
                        app:cornerRadius="14dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRight"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="▶"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    app:backgroundTint="#2C2C2E"
                    app:cornerRadius="14dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHideControls"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Hide View"
                    android:textColor="#E0E0E0"
                    app:cornerRadius="10dp"
                    app:strokeColor="#444444" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textColor="#D12012"
                    app:cornerRadius="10dp"
                    app:strokeColor="#D12012" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCALE"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekScale"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:max="150"
                    android:progressTint="#5800D1"
                    android:thumbTint="#5800D1" />

                <EditText
                    android:id="@+id/etScalePercent"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="#2C2C2E"
                    android:gravity="center"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:text="100"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveLayout"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Save Config"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    app:backgroundTint="#5800D1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadLayout"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Load Config"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    app:backgroundTint="#2C2C2E"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowControlsFloating"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:layout_marginBottom="20dp"
        android:text="Show Controls"
        app:cornerRadius="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
