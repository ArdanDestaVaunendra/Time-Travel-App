<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/default_bg"
        tools:ignore="ContentDescription"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="0dp" />

    <TextView
        android:id="@+id/tvTicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="9dp"
        android:elevation="10dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/samsung_one_400"
        android:marqueeRepeatLimit="marquee_forever"
        android:maxWidth="150dp"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="TELKOMSEL · Emergency call only"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/statusBarContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="9dp"
        android:paddingEnd="27dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivWifi"
            android:layout_width="16dp"
            android:layout_height="15dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/ic_wifi"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv4g1"
                android:layout_width="12dp"
                android:layout_height="14dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_4g"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/ivSignal1"
                android:layout_width="12dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_signal_plain"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv4g2"
                android:layout_width="12dp"
                android:layout_height="14dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_4g"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/ivSignal2"
                android:layout_width="12dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_signal_plain"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBatteryLevel"
            android:layout_width="24dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_battery_dynamic"
            android:fontFamily="@font/samsung_one_400"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingStart="1dp"
            android:paddingTop="0dp"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp"
            android:text="90"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvBigClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="-130dp"
        android:fontFamily="@font/samsung_one_700"
        android:letterSpacing="0"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="4"
        android:shadowRadius="10"
        android:text="06:13"
        android:textColor="#FFFFFF"
        android:textSize="84sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.12" />

    <ImageView
        android:id="@+id/ivLock"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="21dp"
        android:padding="24dp"
        android:src="@drawable/ic_lock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-20dp"
        android:fontFamily="@font/samsung_one_700"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="5"
        android:text="Sat, Jan 24"
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBigClock" />

    <TextView
        android:id="@+id/tvMarqueeBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:marqueeRepeatLimit="marquee_forever"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:text="Running Text"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/bgPhone"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_circle_translucent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/ivPhone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_phone"
        app:layout_constraintBottom_toBottomOf="@id/bgPhone"
        app:layout_constraintEnd_toEndOf="@id/bgPhone"
        app:layout_constraintStart_toStartOf="@id/bgPhone"
        app:layout_constraintTop_toTopOf="@id/bgPhone" />

    <View
        android:id="@+id/bgCamera"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_circle_translucent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/ivCamera"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_camera"
        app:layout_constraintBottom_toBottomOf="@id/bgCamera"
        app:layout_constraintEnd_toEndOf="@id/bgCamera"
        app:layout_constraintHorizontal_bias="0.473"
        app:layout_constraintStart_toStartOf="@id/bgCamera"
        app:layout_constraintTop_toTopOf="@id/bgCamera" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pinScreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/imgPinBackgroundBlurred"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <ImageView
            android:id="@+id/ivLockIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="21dp"
            android:padding="24dp"
            android:src="@drawable/ic_lock"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.28" />

        <TextView
            android:id="@+id/tvEnterPinLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Enter PIN"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/guidelineCenter" />

        <TextView
            android:id="@+id/tvPinInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="Your PIN contains at least 6 digits."
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEnterPinLabel" />

        <LinearLayout
            android:id="@+id/pinIndicatorsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPinInfoLabel">

            <TextView
                android:id="@+id/tvPinError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Incorrect PIN"
                android:textColor="#FF0000"
                android:textSize="18sp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/pinIndicatorsLayout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/pinIndicatorsLayout" />

            <View
                android:id="@+id/dot1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />

            <View
                android:id="@+id/dot2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />

            <View
                android:id="@+id/dot3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />

            <View
                android:id="@+id/dot4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />

            <View
                android:id="@+id/dot5"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />

            <View
                android:id="@+id/dot6"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_pin_dot_empty" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/bottomKeypadContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/pinKeypadGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:scaleX="0.9"
                android:scaleY="0.9">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/btnPin1"
                        layout="@layout/item_pin_button"
                        />

                    <include
                        android:id="@+id/btnPin2"
                        layout="@layout/item_pin_button" />

                    <include
                        android:id="@+id/btnPin3"
                        layout="@layout/item_pin_button" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/btnPin4"
                        layout="@layout/item_pin_button" />

                    <include
                        android:id="@+id/btnPin5"
                        layout="@layout/item_pin_button" />

                    <include
                        android:id="@+id/btnPin6"
                        layout="@layout/item_pin_button" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include
                        android:id="@+id/btnPin7"
                        layout="@layout/item_pin_button" />

                    <include
                        android:id="@+id/btnPin8"
                        layout="@layout/item_pin_button" />

                    <include
                        android:id="@+id/btnPin9"
                        layout="@layout/item_pin_button" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnDeletePin"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_margin="12dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="20dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_backspace"
                        app:tint="#FFFFFF" />

                    <include
                        android:id="@+id/btnPin0"
                        layout="@layout/item_pin_button" />

                    <TextView
                        android:id="@+id/btnOk"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_margin="12dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="OK"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnEmergencyPin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_emergency_oval"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="Emergency call"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/imgFloatObject"
        android:layout_width="220dp"
        android:layout_height="300dp"
        android:visibility="gone"
        android:elevation="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter" />

    <View
        android:id="@+id/invisibleShield"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"/>

</androidx.constraintlayout.widget.ConstraintLayout>