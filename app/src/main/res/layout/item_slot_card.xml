<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgSlotIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#F5F5F7"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_save"
            app:tint="#86868B" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLOT 1"
                android:textColor="#86868B"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSlotName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empty Slot"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSlot"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="SAVE"
            android:textColor="#5800D1"
            app:rippleColor="#335800D1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoadSlot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:text="LOAD"
            android:textColor="#FFFFFF"
            app:backgroundTint="#5800D1"
            app:cornerRadius="8dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>